# ─── Database ───────────────────────────────────────────────────────────────
# Leave blank to use a local SQLite file (data.db) — fine for local dev.
# Set both to use the shared Turso cloud DB instead.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string

# ─── AI / Voice ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
